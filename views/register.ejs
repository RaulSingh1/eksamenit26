<%- include("partials/header", { title: "Registrer bruker | Eksamen IT 2026" }) %>

<section class="form-section">
    <div class="container narrow">
        <h1>Registrer bruker</h1>

        <% if (error) { %>
            <p class="error-message"><%= error %></p>
        <% } %>

        <form class="form-box" action="/register" method="POST">
            <label for="username">Brukernavn</label>
            <input id="username" name="username" type="text" placeholder="Velg et brukernavn" required>

            <label for="password">Passord</label>
            <input id="password" name="password" type="password" placeholder="Velg et passord" required>

            <p class="form-help">Nye brukere registreres som elev. Lærerbrukere opprettes av admin.</p>

            <button class="button" type="submit">Registrer</button>
        </form>
    </div>
</section>

<%- include("partials/footer") %>
